{
  "name": "backend",
  "version": "0.0.1",
  "description": "Chat with your PDF using this AI agent",
  "author": "Mayo Oshin",
  "license": "MIT",
  "private": true,
  "type": "module",
  "scripts": {
    "server:dev": "tsx src/server.ts",
    "build": "tsc",
    "clean": "rm -rf dist",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:changed": "jest --onlyChanged --passWithNoTests",
    "test:related": "jest --findRelatedTests",
    "test:coverage": "jest --coverage",
    "test:int": "jest --testPathPattern=\\.int\\.test\\.ts$",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "lint": "eslint src",
    "lint:fix": "eslint src --fix",
    "lint:langgraph-json": "node scripts/checkLanggraphPaths.js",
    "lint:all": "yarn lint & yarn lint:langgraph-json",
    "langgraph:dev": "npx @langchain/langgraph-cli dev"
  },
  "dependencies": {
    "@langchain/community": "^0.3.26",
    "@langchain/google-genai": "0.1.7",
    "@langchain/core": "^0.3.32",
    "@langchain/langgraph": "^0.2.41",
    "@langchain/langgraph-cli": "^0.0.1",
    "@langchain/langgraph-sdk": "^0.0.36",
    "@langchain/openai": "^0.3.17",
    "@langchain/textsplitters": "^0.1.0",
    "@supabase/supabase-js": "^2.48.1",
    "bcryptjs": "^2.4.3",
    "cors": "^2.8.5",
    "express": "^4.18.2",
    "express-rate-limit": "^7.4.1",
    "helmet": "^8.0.0",
    "jsonwebtoken": "^9.0.2",
    "mongoose": "^8.9.0",
    "multer": "^1.4.5-lts.1",
    "pdf-parse": "^1.1.1",
    "uuid": "^11.0.5",
    "ws": "^8.18.0",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.1.0",
    "@eslint/js": "^9.9.1",
    "@jest/globals": "^29.7.0",
    "@tsconfig/recommended": "^1.0.7",
    "@types/bcryptjs": "^2.4.6",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/jest": "^29.5.0",
    "@types/jsonwebtoken": "^9.0.7",
    "@types/multer": "^1.4.12",
    "@types/node": "^22.10.6",
    "@types/ws": "^8.5.13",
    "@typescript-eslint/eslint-plugin": "5.59.8",
    "@typescript-eslint/parser": "5.59.8",
    "cross-env": "^7.0.3",
    "dotenv": "^16.4.7",
    "eslint": "^8.41.0",
    "eslint-config-prettier": "^8.8.0",
    "eslint-plugin-import": "^2.27.5",
    "eslint-plugin-no-instanceof": "^1.0.1",
    "eslint-plugin-prettier": "^4.2.1",
    "jest": "^29.7.0",
    "prettier": "^3.3.3",
    "ts-jest": "^29.2.5",
    "tsx": "^4.19.2",
    "typescript": "^5.3.3"
  }
}
