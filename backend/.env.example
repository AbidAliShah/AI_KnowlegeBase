# Google Gemini — get a free key at https://aistudio.google.com/
GOOGLE_API_KEY=your-google-api-key-here

# MongoDB (install locally or use MongoDB Atlas free tier)
MONGODB_URI=mongodb://localhost:27017/knowledgeai

# JWT � change this to a long random secret in production
JWT_SECRET=change-me-to-a-long-random-secret-string

PORT=3001
FRONTEND_URL=http://localhost:3000

# Supabase � required for PDF embedding storage
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# LangSmith (optional tracing)
LANGCHAIN_TRACING_V2=false
LANGCHAIN_API_KEY=
LANGCHAIN_PROJECT=knowledgeai
